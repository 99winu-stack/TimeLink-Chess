<UserControl x:Class="GameUI.PromotionMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GameUI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Width="275"
            Height="125"
            Style="{StaticResource BorderStyle}">
        <Grid RenderOptions.BitmapScalingMode="HighQuality">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1.5*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="SELECT A PIECE"
                       Style="{StaticResource TextStyle}"
                       FontSize="28"/>

            <UniformGrid Grid.Row="1"
                         Rows="1"
                         Columns="4">
                <Image x:Name="QueenIMG"
                       MouseDown="QueenIMG_MouseDown"
                       Source="/Assets/queenP.png"/>
                <Image x:Name="BishopIMG"
                       MouseDown="BishopIMG_MouseDown"
                       Source="/Assets/bishopP.png"/>
                <Image x:Name="RookIMG"
                       MouseDown="RookIMG_MouseDown"
                       Source="/Assets/rookP.png"/> 
                <Image x:Name="KnightIMG"
                       MouseDown="KnightIMG_MouseDown"
                       Source="/Assets/KnightP.png"/>
            </UniformGrid>
        </Grid>
            
    </Border>
</UserControl>
